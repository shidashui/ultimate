{
  "build": {
    "distDir": "../dist",
    "devPath": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.ultimate.jarvis-ui",
      "icon": ["icons/32x32.png", "icons/128x128.png"]
    },
    "windows": [
      {
        "title": "JARVIS",
        "width": 900,
        "height": 600,
        "resizable": true,
        "decorations": false,
        "visible": false,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  }
}
